# Server Configuration
PORT=8080
ENVIRONMENT=development

# API Keys (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Cloud Vision for backup OCR
GOOGLE_CLOUD_VISION_KEY=your_cloud_vision_key_here
ENABLE_CLOUD_VISION=false

# Database
DB_PATH=./data/hand_learning.db

# Room Data (JSON file path)
ROOM_DATA_PATH=./data/rooms.json

# Limits
MAX_FILE_SIZE=10485760
MAX_BATCH_SIZE=10

# Features
ENABLE_LEARNING=true
LEARNING_THRESHOLD=0.7

# OCR Timeout (seconds)
OCR_TIMEOUT=30
